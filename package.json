{
  "name": "cue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "qr": "evenhub qr",
    "pack": "evenhub pack app.json dist -o cue.ehpk",
    "deploy": "npm run build && npm run pack && echo '\\ncue.ehpk ready: '$(pwd)'/cue.ehpk\\nUpload to https://hub.evenrealities.com/application'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/regression.mjs"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.7.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10"
  }
}
